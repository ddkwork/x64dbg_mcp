            set(_inc_args "")
            foreach(_inc ${X86_INCLUDE_DIRS})
                list(APPEND _inc_args "/I" "${_inc}")
            endforeach()
            string(REPLACE "${CMAKE_CURRENT_BINARY_DIR}/" "" _obj_rel "${_obj}")
            add_custom_command(
                OUTPUT "${_obj}"
                COMMAND "${X86_RC}" ${_inc_args} /fo ${_obj_rel} "${CMAKE_CURRENT_SOURCE_DIR}/${_src}"
                DEPENDS "${CMAKE_CURRENT_SOURCE_DIR}/${_src}" ${X86_DEPENDS}
                WORKING_DIRECTORY "${CMAKE_CURRENT_BINARY_DIR}"
                VERBATIM
            )
        else()
            set(_inc_args "")
            foreach(_inc ${X86_INCLUDE_DIRS})
                list(APPEND _inc_args "/I" "${_inc}")
            endforeach()
            set(_def_args "")
            foreach(_def ${X86_DEFINITIONS})
                list(APPEND _def_args "/D" "${_def}")
            endforeach()
            string(REPLACE "${CMAKE_CURRENT_BINARY_DIR}/" "" _obj_rel "${_obj}")
            add_custom_command(
                OUTPUT "${_obj}"
                COMMAND "${X86_CL}" /c /nologo /W3 /EHsc /utf-8 /std:c++latest /O2 /Zi /MD /FS
                    ${_inc_args} ${_def_args} ${X86_COMPILE_FLAGS}
                    /Fo${_obj_rel} /Fd${_target}/${_target}.pdb
                    "${CMAKE_CURRENT_SOURCE_DIR}/${_src}"
                DEPENDS "${CMAKE_CURRENT_SOURCE_DIR}/${_src}" ${X86_DEPENDS}
                WORKING_DIRECTORY "${CMAKE_CURRENT_BINARY_DIR}"
                VERBATIM
            )
        endif()
        list(APPEND _obj_list "${_obj}")
        list(APPEND _compile_deps "${CMAKE_CURRENT_SOURCE_DIR}/${_src}")
    endforeach()

    set(_output_dll "${CMAKE_CURRENT_BINARY_DIR}/${_target}.dp32")

    set(_lib_path_args "")
    foreach(_ld ${X86_LINK_DIRS})
        list(APPEND _lib_path_args "/LIBPATH:${_ld}")
    endforeach()

    string(REPLACE "${CMAKE_CURRENT_BINARY_DIR}/" "" _dll_rel "${_output_dll}")
    string(REPLACE "${CMAKE_CURRENT_BINARY_DIR}/" "" _implib_rel "${_output_dir}/${_target}.lib")
    add_custom_command(
        OUTPUT "${_output_dll}"
        COMMAND "${X86_LINK}" /nologo /DLL /MACHINE:X86 /DEBUG
            /OUT:${_dll_rel}
            /IMPLIB:${_implib_rel}
            /PDB:${_target}/${_target}.pdb
            ${_lib_path_args} ${X86_LINK_LIBS}
            ${_obj_list}
        DEPENDS ${_obj_list} ${X86_DEPENDS}
        WORKING_DIRECTORY "${CMAKE_CURRENT_BINARY_DIR}"
        VERBATIM
    )

    add_custom_target(${_target} ALL DEPENDS "${_output_dll}")
endfunction()